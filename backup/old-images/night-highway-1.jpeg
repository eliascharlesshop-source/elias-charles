<?xml version="1.0" encoding="UTF-8"?>
<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="nightGradient1" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#1a1a2e;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#16213e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0f3460;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="100%" height="100%" fill="url(#nightGradient1)"/>
  <!-- Road -->
  <path d="M0,400 L800,350 L800,600 L0,600 Z" fill="#333333"/>
  <!-- Light streaks -->
  <ellipse cx="200" cy="375" rx="40" ry="8" fill="#ff6b6b" opacity="0.6"/>
  <ellipse cx="400" cy="365" rx="60" ry="10" fill="#4ecdc4" opacity="0.7"/>
  <ellipse cx="600" cy="358" rx="50" ry="9" fill="#ffe66d" opacity="0.8"/>
  <!-- Stars -->
  <circle cx="100" cy="100" r="2" fill="white"/>
  <circle cx="300" cy="80" r="1.5" fill="white"/>
  <circle cx="500" cy="120" r="2" fill="white"/>
  <circle cx="700" cy="90" r="1" fill="white"/>
  <text x="400" y="50" text-anchor="middle" fill="white" font-size="20" font-family="Arial, sans-serif">Night Highway 1</text>
</svg>
