<?xml version="1.0" encoding="UTF-8"?>
<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="nightGradient2" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#2c1810;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#1a1a2e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#16213e;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="100%" height="100%" fill="url(#nightGradient2)"/>
  <!-- Road -->
  <path d="M0,450 L800,400 L800,600 L0,600 Z" fill="#2a2a2a"/>
  <!-- Center line -->
  <rect x="0" y="425" width="800" height="2" fill="#ffff00" opacity="0.6"/>
  <!-- Light trails -->
  <ellipse cx="150" cy="425" rx="80" ry="12" fill="#ff4757" opacity="0.5"/>
  <ellipse cx="350" cy="415" rx="120" ry="15" fill="#3742fa" opacity="0.6"/>
  <ellipse cx="650" cy="408" rx="100" ry="13" fill="#2ed573" opacity="0.7"/>
  <!-- Buildings silhouette -->
  <rect x="50" y="200" width="60" height="200" fill="#0a0a0a"/>
  <rect x="150" y="150" width="40" height="250" fill="#0a0a0a"/>
  <rect x="600" y="180" width="80" height="220" fill="#0a0a0a"/>
  <text x="400" y="50" text-anchor="middle" fill="white" font-size="20" font-family="Arial, sans-serif">Night Highway 2</text>
</svg>
